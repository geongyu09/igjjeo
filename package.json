{
  "name": "igjjeo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --cwd apps/web dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "build:ios": "bun run --cwd apps/mobile dev-build:ios",
    "build:android": "bun run --cwd apps/mobile dev-build:android",
    "build:web": "bun run --cwd apps/web build",
    "typecheck": "bun run --cwd apps/web typecheck && bun run --cwd apps/mobile typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~57.0.6",
    "react": "19.2.3",
    "react-native": "0.86.0"
  }
}
