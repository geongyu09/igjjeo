{
  "expo": {
    "name": "이거진짜예요?",
    "slug": "igjjeo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "igjjeo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.geongyu09.igjjeo",
      "appleTeamId": "3XD9F9256D",
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:igjjeo-web.vercel.app"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.geongyu09.igjjeo",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "igjjeo-web.vercel.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.84706556054-3id8s7h6pqqq03vm9slabuafraikb82a"
        }
      ]
    ]
  }
}
