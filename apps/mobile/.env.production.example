# 프로토타입(Release·standalone) 빌드 전용 env 템플릿.
# 실제 파일은 커밋하지 않는다:  cp .env.production.example .env.production  후 채운다.
# proto-build-ios.sh(= bun run dev-build:ios:proto)가 Release 빌드 시 로드한다.
#
# 반드시 "배포된" 호스팅 주소여야 한다 (localhost·사설 LAN IP면 스크립트가 중단시킴) —
# standalone 앱은 개발 머신 없이 단독으로 뜨므로 개발 머신 LAN 주소로는 동작하지 않는다.
# 참고: 여기 없는 값(구글 클라이언트 ID 등)은 .env 에서 공통으로 로드된다.

# 배포된 Next.js 웹 주소 (예: Vercel — https://igjjeo-web.vercel.app)
EXPO_PUBLIC_WEB_URL=

# 배포된 백엔드(apps/server) 주소. /v1 프리픽스 포함 (예: https://<host>/v1)
EXPO_PUBLIC_API_BASE_URL=
