# 아래 두 URL 은 `bun run dev-build:ios` 실행 시 감지한 LAN IP로 자동 갱신된다.
# 시뮬레이터·브라우저는 localhost로 충분하고, 실기기는 개발 머신의 LAN IP가 필요하다
# (localhost는 폰 자신을 가리킴).

# WebView가 띄울 Next.js 웹 주소. (예: http://192.168.0.10:3000)
EXPO_PUBLIC_WEB_URL=http://localhost:3000

# 네이티브 로그인이 소셜 id_token 을 넘길 백엔드(apps/server) 주소. /v1 프리픽스 포함.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/v1
