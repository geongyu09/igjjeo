# NestJS 도메인 백엔드 환경변수. 실제 값은 apps/server/.env (커밋 금지).

# HTTP 포트
API_PORT=4000

# Supabase — DB 전용으로 사용. service_role 키는 서버에서만, 절대 클라이언트 노출 금지.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI 각색 프로바이더 ───────────────────────────────────────────────
# 교체는 AI_PROVIDER 한 줄만 바꾸면 된다 (anthropic | gemini). 코드 수정 없음.
# 선택한 쪽의 키만 있으면 부팅되고, 안 쓰는 쪽 키는 비워둬도 된다.
AI_PROVIDER=gemini
#
# AI_MODEL 은 "비워두면 코드의 기본 모델"을 쓴다는 뜻이다(값이 없어도 정상).
#   - anthropic 기본: claude-haiku-4-5
#   - gemini 기본:    gemini-3.5-flash
# 다른 모델을 쓰고 싶을 때만 채운다. 쓸 수 있는 gemini 모델 확인:
#   curl -H "x-goog-api-key: $GEMINI_API_KEY" \
#     "https://generativelanguage.googleapis.com/v1beta/models" | grep '"name"'
#   (목록에 보여도 신규 계정은 404 나는 모델이 있다 — 예: gemini-2.5-flash)
AI_MODEL=

# AI_PROVIDER=anthropic 일 때 필요.
ANTHROPIC_API_KEY=
# AI_PROVIDER=gemini 일 때 필요. https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=

# 세션 토큰(JWT) 서명 시크릿. 서버 전용, 절대 클라이언트 노출 금지. 충분히 긴 랜덤 값.
JWT_SECRET=

# 소셜 로그인(Google/Apple) id_token 검증용 audience.
# GOOGLE: Google Cloud OAuth "웹 클라이언트" ID (모바일이 이 값을 serverClientId 로 요청 → id_token aud 가 이 값).
GOOGLE_OAUTH_CLIENT_ID=
# APPLE: iOS 앱 번들 ID (네이티브 Sign in with Apple 의 id_token aud).
APPLE_OAUTH_CLIENT_ID=
