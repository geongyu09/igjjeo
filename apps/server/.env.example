# NestJS 도메인 백엔드 환경변수. 실제 값은 apps/server/.env (커밋 금지).

# HTTP 포트
API_PORT=4000

# Supabase — DB 전용으로 사용. service_role 키는 서버에서만, 절대 클라이언트 노출 금지.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# AI 각색 어댑터 (Anthropic). 서버 내부에서만 호출.
ANTHROPIC_API_KEY=

# 세션 토큰(JWT) 서명 시크릿. 서버 전용, 절대 클라이언트 노출 금지. 충분히 긴 랜덤 값.
JWT_SECRET=

# 소셜 로그인(Google/Apple) id_token 검증용 audience.
# GOOGLE: Google Cloud OAuth "웹 클라이언트" ID (모바일이 이 값을 serverClientId 로 요청 → id_token aud 가 이 값).
GOOGLE_OAUTH_CLIENT_ID=
# APPLE: iOS 앱 번들 ID (네이티브 Sign in with Apple 의 id_token aud).
APPLE_OAUTH_CLIENT_ID=
